PORT=3000

# MySQL（若与 Redis 同机，REDIS_HOST 与 DATABASE_URL 里的主机一致即可）
# example: mysql://user:pass@127.0.0.1:3306/ic_test?charset=utf8mb4
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/ic_test?charset=utf8mb4

# Redis（可选；不设 REDIS_HOST 则不走缓存，接口仍可用）
# REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
REDIS_COMMAND_TIMEOUT_MS=5000

# WeChat Mini Program
WX_APPID=wx_xxx
WX_APPSECRET=your_app_secret

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# COS（测试示例与当前环境一致时可照抄桶/地域；密钥务必只放本地 .env）
COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxx
COS_SECRET_KEY=xxxxxxxxxxxxxxxx
COS_BUCKET=chengly-1361977936
COS_REGION=ap-shanghai
# 同一桶内用前缀隔离环境：测试 test、正式 prod（勿带尾部 /）
# 对象路径形如 {COS_ENV_PREFIX}/{forum|task|...}/{img|vid}/{userId}/文件名
COS_ENV_PREFIX=test
COS_STS_DURATION_SECONDS=1800
COS_PRESIGN_EXPIRES_SECONDS=600

# 管理端调用的 HTTP API 根地址（云函数 HTTP 触发 / 自建网关）
VITE_API_BASE=http://127.0.0.1:3000

# 开发时无后端：填 true 则任意账号密码可登录（仅本地）
VITE_DEV_MOCK_AUTH=false
